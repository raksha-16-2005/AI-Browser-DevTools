{
  "manifest_version": 3,
  "name": "AI DevTools",
  "version": "0.0.1",
  "description": "AI-powered browser error explainer",

  "icons": {
    "16":  "public/icon16.png",
    "32":  "public/icon32.png",
    "48":  "public/icon48.png",
    "128": "public/icon128.png"
  },

  "action": {
    "default_icon": {
      "16":  "public/icon16.png",
      "32":  "public/icon32.png"
    },
    "default_title": "Open AI DevTools"
  },

  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },

  "devtools_page": "public/devtools.html",

  "side_panel": {
    "default_path": "public/panel.html"
  },

  "permissions": [
    "sidePanel",
    "storage",
    "scripting",
    "tabs",
    "activeTab"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "content_scripts": [
    {
        "matches": ["<all_urls>"],
        "js": ["src/content-main.ts"],
        "run_at": "document_start",
        "world": "MAIN"
    },
    {
        "matches": ["<all_urls>"],
        "js": ["src/content-relay.ts"],
        "run_at": "document_start",
        "world": "ISOLATED"
    }
  ],

  "commands": {
    "explain-last-error": {
        "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
        },
        "description": "Explain the last captured error"
    }
    }
}